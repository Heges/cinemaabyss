{
  "Kafka": {
    "ServerUrl": "localhost:9092",
    "GroupId": "cinemaabyss-events-service",
    "Topics": {
      "Movie": "movie-events",
      "User": "user-events",
      "Payment": "payment-events"
    },
    "EventMessageProducer": {
      "LingerMs": "5",
      "RetryBackoffMs": "200",
      "FlushTimeFromSeconds": "5"
    },
    "EventMessageConsumer": {
      "DelayMs": "200",
      "RetryAttemptSec": "2"
    },
    "EventKafkaConsumer": {
      "CommitOffsetTimeoutMs": "5000"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
